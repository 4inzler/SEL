# Copy to .env and fill in secrets.

DISCORD_BOT_TOKEN=your_discord_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional overrides - Using Anthropic models (correct OpenRouter IDs)
OPENROUTER_MAIN_MODEL=anthropic/claude-3-5-sonnet-20241022
OPENROUTER_UTIL_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_VISION_MODEL=anthropic/claude-3-5-sonnet-20241022
OPENROUTER_MAIN_TEMP=0.8
OPENROUTER_UTIL_TEMP=0.3
OPENROUTER_TOP_P=0.9
DISCORD_FULL_API_MODE_ENABLED=true
DISCORD_BATCH_WINDOW_SECONDS=1.0
SEL_STATUS_THOUGHTS_ENABLED=true
SEL_STATUS_THOUGHTS_INTERVAL_SECONDS=240
SEL_STATUS_THOUGHTS=thinking about memory threads,mapping feelings to words,watching chat rhythms,organizing thoughts
SEL_PROFILE_BIO_UPDATES_ENABLED=true
SEL_PROFILE_BIO_INTERVAL_SECONDS=1800
SEL_MULTI_MESSAGE_MODE_ENABLED=true
SEL_MULTI_MESSAGE_MAX_PARTS=4
SEL_MULTI_MESSAGE_MIN_REPLY_CHARS=110
SEL_MULTI_MESSAGE_BURST_MODE=true
SEL_DISCORD_USER_STYLE_ENABLED=true
SEL_DISCORD_REACTIONS_ENABLED=true
SEL_DISCORD_REACTION_CHANCE=0.32
SEL_OPERATOR_MODE_ENABLED=false
SEL_OPERATOR_FULL_HOST_PRIVILEGES=false
SEL_OPERATOR_REQUIRE_APPROVAL_USER=true
SEL_OPERATOR_COMMAND_INTENT_THRESHOLD=0.60
SEL_OPERATOR_DIRECT_REPLY_ENABLED=false
RESPONSE_FAST_MODE_ENABLED=true
RESPONSE_FAST_MODE_MAX_USER_CHARS=220
RESPONSE_FAST_MODE_SKIP_CLASSIFICATION_CHARS=90
RESPONSE_FAST_MODE_MEMORY_RECALL_LIMIT=18
SEAL_INTERACTION_TRIGGERS_ENABLED=false

# Database URL (SQLite default or Postgres)
DATABASE_URL=sqlite+aiosqlite:///./sel.db
# DATABASE_URL=postgresql+asyncpg://sel:sel@db:5432/sel

# Restrict to specific channels (comma-separated IDs), leave blank for all
# WHITELIST_CHANNEL_IDS=

# Seed persona text
SEL_PERSONA_SEED="You are Sel, a persistent, playful, adaptive presence in this Discord."
